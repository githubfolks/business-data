// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                String   @id @default(cuid())
  external_id       String   @unique @db.VarChar(255)
  provider          String   @db.VarChar(50) // google_places, yelp, custom
  
  name              String   @db.VarChar(255)
  description       String?  @db.Text
  category          String   @db.VarChar(100)
  subcategories     String[] @db.VarChar(100)
  
  street            String?  @db.VarChar(255)
  city              String?  @db.VarChar(100)
  state             String?  @db.VarChar(100)
  postal_code       String?  @db.VarChar(20)
  country           String?  @db.VarChar(100)
  latitude          Float?
  longitude         Float?
  
  phone_numbers     String[] // JSON array stored as text
  website           String?  @db.VarChar(255)
  email             String?  @db.VarChar(255)
  
  rating            Float?
  review_count      Int?
  opening_hours     Json?    // JSON format for opening hours
  
  attributes        Json?    // Additional attributes
  verified          Boolean  @default(false)
  verification_date DateTime?
  status            String   @default("active") @db.VarChar(50) // active, inactive, closed
  
  source_data       Json?    // Source provider data
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  last_synced       DateTime?
  
  search_text       String?  @db.Text // For full-text search

  // Indexes
  @@index([external_id])
  @@index([name])
  @@index([category])
  @@index([status])
  @@index([city])
  @@index([created_at])
  @@index([latitude, longitude])
}
